    "cleanup:github": "npx tsx scripts/cleanup-github-artifacts.ts",
    "cleanup:titles": "npx tsx scripts/cleanup-titles.ts",
    "ingest:github": "npx tsx scripts/ingest-github.ts",
    "ingest:hn": "npx tsx scripts/ingest-hn.ts",
    "ingest:rss": "npx tsx scripts/ingest-rss.ts",
    "ingest:all": "npx tsx scripts/ingest-all.ts",
    "fix:rss-feeds": "npx tsx scripts/fix-rss-feeds.ts",
    "enrich": "npx tsx scripts/enrich-items.ts",
    "rank": "npx tsx scripts/rank-items.ts"
  },
  "dependencies": {
