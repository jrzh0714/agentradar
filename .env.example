# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI provider — 'anthropic' | 'openai' | 'mock'
# mock: deterministic output, no API key required (useful for CI / local dev)
AI_PROVIDER=openai

# Per-provider model (each has a sensible default if omitted)
# OpenAI default: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
# Anthropic default: claude-3-5-haiku-20241022
ANTHROPIC_MODEL=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# GitHub — personal access token for Search API (5000 req/hr vs 60 unauth)
GITHUB_TOKEN=

# Cron protection — protects /api/refresh/daily from unauthorized access.
# Generate with: openssl rand -hex 32
# Set the same value in your Vercel project environment variables so that
# Vercel Cron automatically passes it as "Authorization: Bearer <CRON_SECRET>".
# Optional: cap items enriched per cron run (default: 150)
CRON_SECRET=
# DAILY_ENRICH_LIMIT=150
