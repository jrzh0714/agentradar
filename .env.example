# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI provider — 'anthropic' is the default; add 'openai' support in lib/ai/provider.ts
AI_PROVIDER=anthropic
AI_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# GitHub — personal access token for Search API (5000 req/hr vs 60 unauth)
GITHUB_TOKEN=

# Cron protection — added in a later phase when API routes are exposed
# CRON_SECRET=
